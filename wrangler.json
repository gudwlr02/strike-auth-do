{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "strike-auth-do",
  "main": "src/index.ts",
  "compatibility_date": "2025-10-08",
  "upload_source_maps": true,
  "migrations": [
    {
      "new_sqlite_classes": ["MyDurableObject"],
      "tag": "v1"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "MyDurableObject",
        "name": "MY_DURABLE_OBJECT"
      }
    ]
  },
  "kv_namespaces": [
    {
      "binding": "AUTH_KV",
      "id": "AUTH_KV"
    }
  ],
  "observability": {
    "enabled": true
  }
}
